{
  "ignorePatterns": [
    { "pattern": "^https://img.shields.io/" },
    { "pattern": "^https://opentimestamps.org" }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com"],
      "headers": { "Accept": "text/html" }
    }
  ],
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 429]
}
